        <!-- Layer 2 — historical-bytes regex match.
             Sürüm bayt'ları dışında vendor parmak izi sabit olduğu için yeni AKIS
             sürümleri Layer 1 listesini güncellemeden otomatik tanınır. -->

        <!-- UEKAE ailesi (eski AKIS NES, 2011-2019): 80 67 [UEKAE] [ver] [318073B3A180] -->
        <atr-pattern regex="806755454B4145....318073B3A180"/>

        <!-- TC ailesi (yeni AKIS NES + T.C. Kimlik 2020+): 80 65 [TC] [ver] [31C073F6218081] [tail] -->
        <atr-pattern regex="80655443......31C073F6218081.."/>
    </card-type>


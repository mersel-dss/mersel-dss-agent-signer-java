        <hint os="linux">/usr/lib</hint>
        <hint os="linux">/usr/lib64</hint>
        <hint os="linux">/usr/lib/x86_64-linux-gnu</hint>
        <hint os="linux">/usr/local/lib</hint>
        <hint os="linux">/opt/akis</hint>
        <hint os="linux">/opt/akis/lib</hint>

        <hint os="macos">/usr/local/lib</hint>
        <hint os="macos">/Library/Akis</hint>
        <hint os="macos">/Library/Application Support/AKIS</hint>
        <hint os="macos">/Applications/AKIS.app/Contents/MacOS</hint>
        <hint os="macos">/opt/homebrew/lib</hint>

        <!-- Layer 1 — exact ATR match -->
        <atr>3BBA11008131FE4D55454B41452056312E30AE</atr>
